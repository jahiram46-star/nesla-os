APP_NAME=NESLA OS
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_IDS=openai/gpt-4o-mini,anthropic/claude-3.5-sonnet,meta-llama/llama-3.1-70b-instruct
OPENROUTER_FALLBACK_MODEL_IDS=openai/gpt-4o-mini,anthropic/claude-3.5-sonnet,meta-llama/llama-3.1-70b-instruct,mistralai/mistral-large
OPENROUTER_APP_NAME=NESLA OS
OPENROUTER_REFERER=http://localhost:8000
OPENROUTER_TIMEOUT_SECONDS=60

# Existing backend defaults
DATABASE_URL=sqlite:///./nesla.db
